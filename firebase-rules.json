{
  "rules": {

    // ────────────────────────────────────────────────────────────
    // BUSES — Public read, only server/admin can write
    // Frontend is read-only. Backend simulator writes via Admin SDK.
    // ────────────────────────────────────────────────────────────
    "buses": {
      ".read": true,
      ".write": false,

      "$busId": {
        ".validate": "newData.hasChildren(['id','routeKey','lat','lng','speed','direction','crowd','updatedAt'])",

        "id":        { ".validate": "newData.isString()" },
        "routeKey":  { ".validate": "newData.isString()" },
        "lat":       { ".validate": "newData.isNumber() && newData.val() >= -90  && newData.val() <= 90" },
        "lng":       { ".validate": "newData.isNumber() && newData.val() >= -180 && newData.val() <= 180" },
        "speed":     { ".validate": "newData.isNumber() && newData.val() >= 0    && newData.val() <= 200" },
        "direction": { ".validate": "newData.isNumber()" },
        "crowd":     { ".validate": "newData.val() === 'low' || newData.val() === 'medium' || newData.val() === 'high'" },
        "status":    { ".validate": "newData.val() === 'normal' || newData.val() === 'delayed' || newData.val() === 'emergency'" },
        "updatedAt": { ".validate": "newData.isNumber()" }
      }
    },

    // ────────────────────────────────────────────────────────────
    // ROUTES — Public read, no client write
    // ────────────────────────────────────────────────────────────
    "routes": {
      ".read": true,
      ".write": false
    },

    // ────────────────────────────────────────────────────────────
    // ALERTS (SOS) — Authenticated users can write their own alerts
    // Authenticated users can read alerts (admin sees all via rules)
    // Only the alert creator or admin can update/delete
    // ────────────────────────────────────────────────────────────
    "alerts": {
      ".read": "auth !== null",

      "$alertId": {
        ".write": "auth !== null && (
          !data.exists() ||
          data.child('userId').val() === auth.uid ||
          root.child('users').child(auth.uid).child('role').val() === 'admin'
        )",

        ".validate": "newData.hasChildren(['type','userId','timestamp','status'])",

        "type":      { ".validate": "newData.val() === 'sos' || newData.val() === 'delay' || newData.val() === 'crowd'" },
        "userId":    { ".validate": "newData.isString() && newData.val() === auth.uid" },
        "userName":  { ".validate": "newData.isString()" },
        "userEmail": { ".validate": "newData.isString()" },
        "location": {
          "lat": { ".validate": "newData.isNumber()" },
          "lng": { ".validate": "newData.isNumber()" }
        },
        "busId":     { ".validate": "!newData.exists() || newData.isString()" },
        "timestamp": { ".validate": "newData.isNumber()" },
        "status":    { ".validate": "newData.val() === 'active' || newData.val() === 'resolved'" }
      }
    },

    // ────────────────────────────────────────────────────────────
    // ANALYTICS — Admin only read/write
    // ────────────────────────────────────────────────────────────
    "analytics": {
      ".read":  "auth !== null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
      ".write": false
    },

    // ────────────────────────────────────────────────────────────
    // USERS — Users can read/write their own profile only
    // Admin can read all profiles
    // ────────────────────────────────────────────────────────────
    "users": {
      ".read": "auth !== null && root.child('users').child(auth.uid).child('role').val() === 'admin'",

      "$userId": {
        ".read":  "auth !== null && (auth.uid === $userId || root.child('users').child(auth.uid).child('role').val() === 'admin')",
        ".write": "auth !== null && auth.uid === $userId",

        ".validate": "newData.hasChildren(['name','email','role'])",

        "name":              { ".validate": "newData.isString() && newData.val().length > 0" },
        "email":             { ".validate": "newData.isString()" },
        "role":              { ".validate": "newData.val() === 'user' || newData.val() === 'admin'" },
        "emergencyContacts": { ".validate": "!newData.exists() || newData.isString()" },
        "createdAt":         { ".validate": "newData.isNumber()" }
      }
    }
  }
}
